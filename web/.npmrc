# Project-local pnpm/npm config — mirrors the registry to a China-friendly
# proxy because the dev environment can't always reach registry.npmjs.org
# directly. Mirrors only; package contents are byte-identical to upstream.
#
# Tracked in git intentionally so every contributor's first `pnpm install`
# uses the same source. To switch back to the official registry simply
# delete this file or override with `pnpm config set registry ...`.
registry=https://registry.npmmirror.com/

# Pin the auto-installed pnpm version so corepack uses the same one
# referenced in package.json's `packageManager` field.
auto-install-peers=true
strict-peer-dependencies=false
